---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { services, testimonials } from '../data/siteConfig';

const featuredServices = services.slice(0, 3);
---

<BaseLayout>
  <Hero />
  <CtaBanner />

  <!-- Featured Services Teaser -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">What I Offer</p>
        <h2 class="text-4xl md:text-5xl text-charcoal font-display mb-4">Services</h2>
        <p class="text-warm-grey max-w-2xl mx-auto">
          Based in Dorset, England — offering in-person and online sessions.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredServices.map((service) => (
          <div class="group bg-warm-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-500 hover:-translate-y-1">
            <div class="h-1" style={`background-color: ${service.accentColor}`}></div>
            <div class="p-8">
              <div
                class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-5"
                style={`background-color: ${service.iconBg}`}
              >
                {service.icon}
              </div>
              <h3 class="text-xl font-display text-charcoal mb-3">{service.title}</h3>
              <p class="text-warm-grey text-sm leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/services/"
          class="bg-sage hover:bg-sage-light text-warm-white px-8 py-3.5 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
        >
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonial Highlight -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">Kind Words</p>
        <h2 class="text-4xl md:text-5xl text-charcoal font-display">What Women Say</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {testimonials.slice(0, 2).map((testimonial, i) => (
          <div class:list={['bg-warm-white rounded-2xl p-10 shadow-sm relative', i % 2 !== 0 && 'md:mt-8']}>
            <div class="absolute -top-4 left-10 w-8 h-8 bg-sage-pale rounded-full flex items-center justify-center">
              <svg class="w-4 h-4 text-sage" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
              </svg>
            </div>
            <p class="text-warm-grey leading-relaxed mb-6 italic">"{testimonial.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sage-pale to-blush"></div>
              <div>
                <p class="text-sm font-medium text-charcoal">{testimonial.name}</p>
                <p class="text-xs text-warm-grey">{testimonial.detail}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-pale/40 via-cream to-blush/20"></div>
    <div class="absolute top-0 left-0 w-72 h-72 bg-sage/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-terracotta-light/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">Take the First Step</p>
      <h2 class="text-4xl md:text-5xl text-charcoal font-display mb-6 leading-tight">Ready to begin your journey?</h2>
      <p class="text-lg text-warm-grey leading-relaxed mb-10 max-w-2xl mx-auto">
        Book a free connection call and let's chat about how I can support you.
      </p>
      <a
        href="/contact/"
        class="bg-sage hover:bg-sage-light text-warm-white px-10 py-4 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
