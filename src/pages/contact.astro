---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import ContactSection from '../components/sections/Contact.astro';
import Community from '../components/sections/Community.astro';
---

<BaseLayout
  title="Contact — Rebirthing Breathwork Mastery"
  description="Get in touch with Natalie Doyle. Book a free connection call or enquire about breathwork sessions, retreats and training in Dorset."
>
  <PageHero
    eyebrow="Get in Touch"
    title="Contact"
    subtitle="Whether you have questions, want to book a session, or just want to say hello — I'd love to hear from you."
    imageAlt="Get in touch"
  />

  <ContactSection />
  <Community />
</BaseLayout>
