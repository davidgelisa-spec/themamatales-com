---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import ServicesSection from '../components/sections/Services.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
---

<BaseLayout
  title="Services — Rebirthing Breathwork Mastery"
  description="One-to-one breathwork, group sessions, retreats, nervous system reset and practitioner training with Natalie Doyle in Dorset and online."
>
  <PageHero
    eyebrow="What I Offer"
    title="Services"
    subtitle="Based in Dorset, England — offering in-person and online sessions."
    imageAlt="Breathwork session"
  />

  <ServicesSection />
  <Testimonials />
  <CtaBanner />
</BaseLayout>
