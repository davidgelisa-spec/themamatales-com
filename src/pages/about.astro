---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutSection from '../components/sections/About.astro';
import Philosophy from '../components/sections/Philosophy.astro';
---

<BaseLayout
  title="About Natalie — Rebirthing Breathwork Mastery"
  description="Meet Natalie Doyle — rebirthing breathwork practitioner and nervous system regulation specialist based in Dorset, guiding women to awaken and embody authentic living."
>
  <!-- Simple coloured hero (no background image) -->
  <section class="relative overflow-hidden flex items-center pt-32 pb-16 md:pb-20">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-pale/50 via-cream to-blush/20"></div>
    <div class="absolute top-0 right-0 w-72 h-72 bg-sage/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-terracotta-light/10 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
      <div class="max-w-xl">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">About</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl text-charcoal font-display mb-4 leading-tight">Meet Natalie</h1>
        <p class="text-lg text-warm-grey leading-relaxed">
          The story behind Rebirthing Breathwork Mastery and the philosophy that drives everything I do.
        </p>
      </div>
    </div>
  </section>

  <AboutSection />
  <Philosophy />
</BaseLayout>
