---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Font Comparison">
  <section class="pt-32 pb-20 bg-cream min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl font-body text-charcoal mb-4 text-center">Elegant Display Fonts with Lowercase</h2>
      <p class="text-warm-grey text-center mb-12">Decorative but soft — the sweet spot between flourish and flow</p>

      <!-- Playfair Display Italic -->
      <div class="mb-10 p-8 bg-warm-white rounded-2xl shadow-sm">
        <p class="text-xs tracking-[0.3em] uppercase text-warm-grey mb-4 font-body">Playfair Display (italic)</p>
        <p class="text-5xl md:text-7xl text-charcoal leading-tight font-playfair italic">The Mama Tales</p>
        <p class="text-3xl text-dusty-rose mt-3 font-playfair italic">Breathe. Regulate. Connect.</p>
      </div>

      <!-- Bodoni Moda Italic -->
      <div class="mb-10 p-8 bg-warm-white rounded-2xl shadow-sm">
        <p class="text-xs tracking-[0.3em] uppercase text-warm-grey mb-4 font-body">Bodoni Moda (italic) — high contrast, editorial elegance</p>
        <p class="text-5xl md:text-7xl text-charcoal leading-tight font-bodoni italic">The Mama Tales</p>
        <p class="text-3xl text-dusty-rose mt-3 font-bodoni italic">Breathe. Regulate. Connect.</p>
      </div>

      <!-- Gilda Display -->
      <div class="mb-10 p-8 bg-warm-white rounded-2xl shadow-sm">
        <p class="text-xs tracking-[0.3em] uppercase text-warm-grey mb-4 font-body">Gilda Display — warm, refined serif with subtle flourish</p>
        <p class="text-5xl md:text-7xl text-charcoal leading-tight font-gilda">The Mama Tales</p>
        <p class="text-3xl text-dusty-rose mt-3 font-gilda">Breathe. Regulate. Connect.</p>
      </div>

      <!-- Cormorant Upright -->
      <div class="mb-10 p-8 bg-warm-white rounded-2xl shadow-sm">
        <p class="text-xs tracking-[0.3em] uppercase text-warm-grey mb-4 font-body">Cormorant Upright — calligraphic serif, upright cursive feel</p>
        <p class="text-5xl md:text-7xl text-charcoal leading-tight font-cormorant-upright">The Mama Tales</p>
        <p class="text-3xl text-dusty-rose mt-3 font-cormorant-upright">Breathe. Regulate. Connect.</p>
      </div>

      <!-- Cormorant Unicase -->
      <div class="mb-10 p-8 bg-warm-white rounded-2xl shadow-sm">
        <p class="text-xs tracking-[0.3em] uppercase text-warm-grey mb-4 font-body">Cormorant Unicase — elegant mixed-case, unique character</p>
        <p class="text-5xl md:text-7xl text-charcoal leading-tight font-cormorant-unicase">The Mama Tales</p>
        <p class="text-3xl text-dusty-rose mt-3 font-cormorant-unicase">Breathe. Regulate. Connect.</p>
      </div>

      <!-- Marcellus -->
      <div class="mb-10 p-8 bg-warm-white rounded-2xl shadow-sm">
        <p class="text-xs tracking-[0.3em] uppercase text-warm-grey mb-4 font-body">Marcellus — classic inscriptional, soft but structured</p>
        <p class="text-5xl md:text-7xl text-charcoal leading-tight font-marcellus">The Mama Tales</p>
        <p class="text-3xl text-dusty-rose mt-3 font-marcellus">Breathe. Regulate. Connect.</p>
      </div>

      <!-- On the gradient -->
      <h2 class="text-2xl font-body text-charcoal mb-8 mt-20 text-center">On the Hero Gradient</h2>

      <div class="relative rounded-2xl overflow-hidden shadow-lg mb-8">
        <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>
        <div class="relative z-10 p-12 md:p-16">
          <p class="text-5xl md:text-7xl font-playfair italic text-warm-white leading-tight mb-2">The Mama<br/>Tales</p>
          <p class="text-xs tracking-[0.3em] uppercase text-warm-white/70 font-body">Playfair Display italic</p>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-lg mb-8">
        <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>
        <div class="relative z-10 p-12 md:p-16">
          <p class="text-5xl md:text-7xl font-bodoni italic text-warm-white leading-tight mb-2">The Mama<br/>Tales</p>
          <p class="text-xs tracking-[0.3em] uppercase text-warm-white/70 font-body">Bodoni Moda italic</p>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-lg mb-8">
        <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>
        <div class="relative z-10 p-12 md:p-16">
          <p class="text-5xl md:text-7xl font-gilda text-warm-white leading-tight mb-2">The Mama<br/>Tales</p>
          <p class="text-xs tracking-[0.3em] uppercase text-warm-white/70 font-body">Gilda Display</p>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-lg mb-8">
        <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>
        <div class="relative z-10 p-12 md:p-16">
          <p class="text-5xl md:text-7xl font-cormorant-upright text-warm-white leading-tight mb-2">The Mama<br/>Tales</p>
          <p class="text-xs tracking-[0.3em] uppercase text-warm-white/70 font-body">Cormorant Upright</p>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-lg mb-8">
        <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>
        <div class="relative z-10 p-12 md:p-16">
          <p class="text-5xl md:text-7xl font-cormorant-unicase text-warm-white leading-tight mb-2">The Mama<br/>Tales</p>
          <p class="text-xs tracking-[0.3em] uppercase text-warm-white/70 font-body">Cormorant Unicase</p>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-lg mb-8">
        <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>
        <div class="relative z-10 p-12 md:p-16">
          <p class="text-5xl md:text-7xl font-marcellus text-warm-white leading-tight mb-2">The Mama<br/>Tales</p>
          <p class="text-xs tracking-[0.3em] uppercase text-warm-white/70 font-body">Marcellus</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Bodoni+Moda:ital,wght@0,400;0,500;1,400;1,500&family=Gilda+Display&family=Cormorant+Upright:wght@400;500;600&family=Cormorant+Unicase:wght@400;500;600&family=Marcellus&display=swap');

  .font-playfair { font-family: 'Playfair Display', serif; }
  .font-bodoni { font-family: 'Bodoni Moda', serif; }
  .font-gilda { font-family: 'Gilda Display', serif; }
  .font-cormorant-upright { font-family: 'Cormorant Upright', serif; }
  .font-cormorant-unicase { font-family: 'Cormorant Unicase', serif; }
  .font-marcellus { font-family: 'Marcellus', serif; }
</style>
