---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import placeholderImage from '../assets/images/natalie-portrait.png';
---

<BaseLayout
  title="Rebirthing Radiant Women Retreat — May 2026, Dorset"
  description="A transformative 2-day breathwork retreat in Wareham, Dorset. 4 rebirthing breathwork sessions, fire ceremonies, sauna, cold plunge, plant-based meals and more. 9–10 May 2026."
>
  <!-- Hero -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne animate-gradient"></div>
    <div class="absolute inset-0 bg-gradient-to-tl from-champagne-light/50 via-transparent to-dusty-rose/30"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-warm-white/10 to-cream/20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/45 via-charcoal/20 to-transparent"></div>

    <div class="absolute top-10 -right-20 w-[500px] h-[500px] bg-champagne/40 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-[400px] h-[400px] bg-dusty-rose-light/40 rounded-full blur-3xl"></div>
    <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-blush/30 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 pt-32 pb-24">
      <div class="max-w-3xl">
        <p class="text-xs tracking-[0.3em] uppercase text-champagne-light mb-5 font-body">
          9 &ndash; 10 May 2026 &middot; Wareham, Dorset
        </p>
        <h1 class="text-4xl md:text-6xl text-warm-white leading-[1.1] mb-6 font-brand italic drop-shadow-sm">
          Rebirthing<br />
          <span class="text-champagne-light">Radiant Women</span>
        </h1>
        <p class="text-xl md:text-2xl text-warm-white/90 leading-relaxed mb-4 font-display italic">
          "Return to the woman you were, before the world told you who to be."
        </p>
        <p class="text-lg text-warm-white/70 leading-relaxed max-w-xl mb-10 font-light">
          A two-day breathwork retreat in the heart of Dorset. Step away from the noise, reconnect with your body
          and remember who you really are.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#booking"
            class="bg-sage hover:bg-sage-light text-warm-white px-10 py-4 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg text-center"
          >
            Reserve Your Place
          </a>
          <a
            href="#details"
            class="border border-warm-white/30 hover:border-sage-light text-warm-white hover:text-sage-light px-10 py-4 rounded-full text-xs tracking-[0.2em] uppercase transition-all text-center"
          >
            See Full Details
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 120L60 108C120 96 240 72 360 66C480 60 600 72 720 78C840 84 960 84 1080 78C1200 72 1320 60 1380 54L1440 48V120H0Z" fill="#FAF6F1"/>
      </svg>
    </div>
  </section>

  <!-- Overview -->
  <section id="details" class="py-20 md:py-28 bg-cream scroll-mt-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">The Retreat</p>
        <h2 class="text-4xl md:text-5xl text-charcoal font-display mb-6">Two days of deep<br /><span class="italic text-sage">transformation</span></h2>
        <p class="text-lg text-warm-grey leading-relaxed max-w-2xl mx-auto">
          Set on the peaceful banks of the River Piddle in Wareham, this intimate retreat is designed for women
          ready to shed what no longer serves them and step into radiant, embodied living.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-warm-white rounded-2xl p-8 shadow-sm text-center">
          <div class="w-14 h-14 rounded-2xl bg-sage-pale flex items-center justify-center text-2xl mx-auto mb-5">🌬️</div>
          <h3 class="text-xl font-display text-charcoal mb-3">4 Breathwork Sessions</h3>
          <p class="text-warm-grey text-sm leading-relaxed">
            Four 90-minute rebirthing breathwork mastery sessions guided by Natalie to release, regulate and restore.
          </p>
        </div>
        <div class="bg-warm-white rounded-2xl p-8 shadow-sm text-center">
          <div class="w-14 h-14 rounded-2xl bg-[rgba(196,132,108,0.15)] flex items-center justify-center text-2xl mx-auto mb-5">🔥</div>
          <h3 class="text-xl font-display text-charcoal mb-3">Fire & Ceremony</h3>
          <p class="text-warm-grey text-sm leading-relaxed">
            Two fire ceremonies, intention-setting circle, welcome ceremony and closing cacao ceremony with live music.
          </p>
        </div>
        <div class="bg-warm-white rounded-2xl p-8 shadow-sm text-center">
          <div class="w-14 h-14 rounded-2xl bg-[rgba(201,169,110,0.15)] flex items-center justify-center text-2xl mx-auto mb-5">🌿</div>
          <h3 class="text-xl font-display text-charcoal mb-3">Nature & Nourishment</h3>
          <p class="text-warm-grey text-sm leading-relaxed">
            Sauna & cold plunge, forest walks, plant-based meals and the stillness of the Dorset countryside.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-pale/40 via-cream to-blush/20"></div>
    <div class="absolute top-0 left-0 w-72 h-72 bg-sage/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-champagne/15 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">Everything Included</p>
        <h2 class="text-4xl md:text-5xl text-charcoal font-display">Your retreat<br /><span class="italic text-sage">experience</span></h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-6">
        {[
          '4 x 90-minute Rebirthing Breathwork Mastery sessions',
          'Intention-setting ceremony',
          'Welcome circle & opening ceremony',
          '2 x fire ceremonies',
          'Co-regulation debrief after each session',
          'Sauna & cold plunge access',
          'Forest walks along the river',
          'Plant-based meals & refreshments',
          'Closing cacao ceremony',
          'Live music experience',
          'Beautiful riverside setting',
          'Small, intimate group of women',
        ].map((item) => (
          <div class="flex items-start gap-3 py-2">
            <span class="text-sage mt-0.5 flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <span class="text-warm-grey">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">The Journey</p>
        <h2 class="text-4xl md:text-5xl text-charcoal font-display">Over two <span class="italic text-sage">days</span></h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Day 1 -->
        <div class="bg-warm-white rounded-2xl overflow-hidden shadow-sm">
          <div class="h-1 bg-sage"></div>
          <div class="p-8">
            <p class="text-xs tracking-[0.3em] uppercase text-sage mb-2 font-body">Saturday 9th May</p>
            <h3 class="text-2xl font-display text-charcoal mb-6">Day One</h3>
            <ul class="space-y-4">
              {[
                { time: 'Morning', activity: 'Arrival, welcome circle & intention-setting ceremony' },
                { time: 'Late Morning', activity: 'Rebirthing Breathwork Session 1 — Opening' },
                { time: 'Lunchtime', activity: 'Plant-based lunch & gentle forest walk' },
                { time: 'Afternoon', activity: 'Rebirthing Breathwork Session 2 — Deepening' },
                { time: 'Evening', activity: 'Fire ceremony, sauna & cold plunge' },
              ].map((item) => (
                <li class="flex gap-4">
                  <span class="text-xs tracking-wider uppercase text-sage font-body w-24 flex-shrink-0 pt-0.5">{item.time}</span>
                  <span class="text-warm-grey text-sm leading-relaxed">{item.activity}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Day 2 -->
        <div class="bg-warm-white rounded-2xl overflow-hidden shadow-sm">
          <div class="h-1 bg-terracotta"></div>
          <div class="p-8">
            <p class="text-xs tracking-[0.3em] uppercase text-sage mb-2 font-body">Sunday 10th May</p>
            <h3 class="text-2xl font-display text-charcoal mb-6">Day Two</h3>
            <ul class="space-y-4">
              {[
                { time: 'Morning', activity: 'Gentle awakening & forest walk by the river' },
                { time: 'Late Morning', activity: 'Rebirthing Breathwork Session 3 — Release' },
                { time: 'Lunchtime', activity: 'Plant-based lunch & rest' },
                { time: 'Afternoon', activity: 'Rebirthing Breathwork Session 4 — Integration' },
                { time: 'Evening', activity: 'Fire ceremony, cacao ceremony & live music closing' },
              ].map((item) => (
                <li class="flex gap-4">
                  <span class="text-xs tracking-wider uppercase text-sage font-body w-24 flex-shrink-0 pt-0.5">{item.time}</span>
                  <span class="text-warm-grey text-sm leading-relaxed">{item.activity}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-champagne-light/30 via-cream to-dusty-rose-light/20"></div>
    <div class="absolute top-0 right-0 w-72 h-72 bg-champagne/20 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <div class="w-12 h-12 bg-sage-pale rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-5 h-5 text-sage" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
        </svg>
      </div>
      <p class="text-xl md:text-2xl text-warm-grey leading-relaxed italic font-display mb-8">
        "My migraines, which I have had regularly since puberty, have reduced to maybe one or two over the past four
        months instead of one or two a week. My fibromyalgia is also improved. My mental health has seen a massive
        improvement. I would recommend Natalie's retreats to any woman ready for change."
      </p>
      <div>
        <p class="text-charcoal font-medium">Kirsty</p>
        <p class="text-sm text-warm-grey">Retreat Participant</p>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">The Setting</p>
          <h2 class="text-4xl md:text-5xl text-charcoal font-display mb-6">The Happy River,<br /><span class="italic text-sage">Wareham</span></h2>
          <p class="text-warm-grey leading-relaxed mb-4">
            Nestled on the banks of the River Piddle in the heart of the Dorset countryside, The Happy River provides
            the perfect setting for deep inner work. Surrounded by ancient woodland and gentle river sounds, you'll
            find it easy to let go and simply be.
          </p>
          <div class="space-y-3 mt-6">
            <div class="flex items-start gap-3">
              <span class="text-sage mt-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </span>
              <div>
                <p class="text-charcoal text-sm font-medium">The Happy River</p>
                <p class="text-warm-grey text-sm">Bere Road, Wareham, Dorset, BH20 7PA</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-sage mt-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </span>
              <div>
                <p class="text-charcoal text-sm font-medium">Saturday 9th & Sunday 10th May 2026</p>
                <p class="text-warm-grey text-sm">Full weekend experience</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Placeholder image -->
        <div class="flex justify-center">
          <div class="relative w-full max-w-md aspect-[4/3]">
            <div class="absolute -inset-3 rounded-[40%_60%_55%_45%/55%_45%_60%_40%] border border-sage-light/30 rotate-2"></div>
            <div class="w-full h-full rounded-[40%_60%_55%_45%/55%_45%_60%_40%] overflow-hidden shadow-md bg-gradient-to-br from-sage-pale to-champagne-light flex items-center justify-center">
              <div class="text-center p-8">
                <span class="text-4xl mb-3 block">🌿</span>
                <p class="text-sage text-sm italic font-display">Venue photo coming soon</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing & Booking -->
  <section id="booking" class="py-20 md:py-28 relative overflow-hidden scroll-mt-20">
    <div class="absolute inset-0 bg-gradient-to-br from-sage-pale via-cream to-blush/30"></div>
    <div class="absolute top-0 right-0 w-72 h-72 bg-sage-light/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-terracotta-light/15 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">Your Investment</p>
        <h2 class="text-4xl md:text-5xl text-charcoal font-display mb-4">Secure your <span class="italic text-sage">place</span></h2>
        <p class="text-warm-grey max-w-xl mx-auto">
          Spaces are limited to keep the retreat intimate and deeply held. Early booking is recommended.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <!-- Full Payment -->
        <div class="bg-warm-white rounded-2xl overflow-hidden shadow-sm relative">
          <div class="h-1 bg-sage"></div>
          <div class="p-8 text-center">
            <p class="text-xs tracking-[0.2em] uppercase text-sage mb-4 font-body">Full Payment</p>
            <p class="text-4xl font-display text-charcoal mb-1">£557</p>
            <p class="text-sm text-warm-grey mb-6">One-time payment</p>
            <a
              href="/contact/"
              class="block bg-sage hover:bg-sage-light text-warm-white px-6 py-3 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
            >
              Book Now
            </a>
          </div>
        </div>

        <!-- Deposit -->
        <div class="bg-warm-white rounded-2xl overflow-hidden shadow-sm relative">
          <div class="h-1 bg-terracotta"></div>
          <div class="p-8 text-center">
            <p class="text-xs tracking-[0.2em] uppercase text-sage mb-4 font-body">Deposit</p>
            <p class="text-4xl font-display text-charcoal mb-1">£167</p>
            <p class="text-sm text-warm-grey mb-6">To secure your place</p>
            <a
              href="/contact/"
              class="block bg-sage hover:bg-sage-light text-warm-white px-6 py-3 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
            >
              Pay Deposit
            </a>
          </div>
        </div>

        <!-- Payment Plan -->
        <div class="bg-warm-white rounded-2xl overflow-hidden shadow-sm relative sm:col-span-2 lg:col-span-1">
          <div class="h-1 bg-champagne"></div>
          <div class="p-8 text-center">
            <p class="text-xs tracking-[0.2em] uppercase text-sage mb-4 font-body">Payment Plan</p>
            <p class="text-4xl font-display text-charcoal mb-1">Flexible</p>
            <p class="text-sm text-warm-grey mb-6">Spread the cost</p>
            <a
              href="/contact/"
              class="block border border-sage hover:bg-sage text-sage hover:text-warm-white px-6 py-3 rounded-full text-xs tracking-[0.2em] uppercase transition-all"
            >
              Enquire
            </a>
          </div>
        </div>
      </div>

      <p class="text-center text-sm text-warm-grey mt-8">
        Have questions? <a href="/contact/" class="text-sage hover:text-sage-light underline underline-offset-4">Get in touch</a> — I'd love to help.
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl text-charcoal font-display mb-6 leading-tight">
        Return to the woman you were,<br />
        <span class="italic text-sage">before the world told you who to be.</span>
      </h2>
      <p class="text-lg text-warm-grey leading-relaxed mb-10 max-w-2xl mx-auto">
        This retreat is your invitation to pause, breathe, and come home to yourself.
        Join us in Dorset this May.
      </p>
      <a
        href="#booking"
        class="bg-sage hover:bg-sage-light text-warm-white px-10 py-4 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
      >
        Reserve Your Place
      </a>
    </div>
  </section>
</BaseLayout>
