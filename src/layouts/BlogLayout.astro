---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, pubDate, updatedDate, category, image, imageAlt } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const formattedUpdated = updatedDate?.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  breathwork: 'Breathwork',
  hypnobirthing: 'Hypnobirthing',
  parenting: 'Parenting',
  pregnancy: 'Pregnancy',
  'nervous-system': 'Nervous System',
  community: 'Community',
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — The Mama Tales</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="The Mama Tales" />
    {image && <meta property="og:image" content={image} />}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Nunito+Sans:ital,opsz,wght@0,6..12,300;0,6..12,400;0,6..12,600;0,6..12,700;1,6..12,300;1,6..12,400&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <style is:global>
      @import "../styles/global.css";
    </style>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-cream/80 backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-serif text-2xl text-warm-brown tracking-wide">The Mama Tales</a>

        <button id="mobile-menu-btn" class="md:hidden text-warm-brown" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <div class="hidden md:flex items-center gap-8">
          <a href="/#offerings" class="text-sm tracking-widest uppercase text-text-light hover:text-warm-brown transition-colors">Offerings</a>
          <a href="/#about" class="text-sm tracking-widest uppercase text-text-light hover:text-warm-brown transition-colors">Our Vision</a>
          <a href="/blog/" class="text-sm tracking-widest uppercase text-warm-brown font-semibold transition-colors">Journal</a>
          <a href="/#contact" class="text-sm tracking-widest uppercase text-text-light hover:text-warm-brown transition-colors">Contact</a>
          <a href="/#offerings" class="bg-rose-300/60 hover:bg-rose-300/80 text-warm-brown text-sm tracking-widest uppercase px-6 py-2.5 rounded-full transition-colors">Book Now</a>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-cream/95 backdrop-blur-md border-t border-blush-200">
        <div class="flex flex-col items-center gap-4 py-6">
          <a href="/#offerings" class="text-sm tracking-widest uppercase text-text-light hover:text-warm-brown transition-colors">Offerings</a>
          <a href="/#about" class="text-sm tracking-widest uppercase text-text-light hover:text-warm-brown transition-colors">Our Vision</a>
          <a href="/blog/" class="text-sm tracking-widest uppercase text-warm-brown font-semibold transition-colors">Journal</a>
          <a href="/#contact" class="text-sm tracking-widest uppercase text-text-light hover:text-warm-brown transition-colors">Contact</a>
          <a href="/#offerings" class="bg-rose-300/60 hover:bg-rose-300/80 text-warm-brown text-sm tracking-widest uppercase px-6 py-2.5 rounded-full transition-colors">Book Now</a>
        </div>
      </div>
    </nav>

    <!-- Article -->
    <main class="pt-28 pb-20 md:pb-28">
      <article class="max-w-3xl mx-auto px-6">
        <!-- Header -->
        <header class="mb-12 text-center">
          <div class="mb-4">
            <span class="inline-block text-xs tracking-[0.3em] uppercase text-rose-400 bg-rose-50 px-4 py-1.5 rounded-full">
              {categoryLabels[category] ?? category}
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl text-warm-brown leading-tight mb-6">{title}</h1>
          <p class="text-lg text-text-light leading-relaxed max-w-2xl mx-auto mb-6">{description}</p>
          <div class="flex items-center justify-center gap-4 text-sm text-text-light">
            <span>{formattedDate}</span>
            {formattedUpdated && (
              <span class="text-warm-gray">· Updated {formattedUpdated}</span>
            )}
          </div>
        </header>

        <!-- Prose content -->
        <div class="prose">
          <slot />
        </div>

        <!-- Back link -->
        <div class="mt-16 pt-8 border-t border-blush-200">
          <a href="/blog/" class="inline-flex items-center gap-2 text-sm tracking-widest uppercase text-rose-400 hover:text-rose-500 transition-colors">
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
            Back to Journal
          </a>
        </div>
      </article>
    </main>

    <!-- Footer -->
    <footer class="bg-warm-brown text-white/70 py-12">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8 items-center">
          <div>
            <p class="font-serif text-xl text-white mb-2">The Mama Tales</p>
            <p class="text-sm">Conscious, Regulated & Authentic Parenting</p>
          </div>
          <div class="text-center">
            <p class="text-sm">Dorset, New Forest & Hampshire, UK</p>
            <p class="text-sm">Online & In-Person</p>
          </div>
          <div class="text-right">
            <p class="text-sm">&copy; {new Date().getFullYear()} The Mama Tales</p>
            <p class="text-sm">All rights reserved</p>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
      menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menu?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
