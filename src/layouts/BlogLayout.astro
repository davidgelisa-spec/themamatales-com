---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, pubDate, updatedDate, category } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const formattedUpdated = updatedDate?.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  breathwork: 'Breathwork',
  hypnobirthing: 'Hypnobirthing',
  parenting: 'Parenting',
  pregnancy: 'Pregnancy',
  'nervous-system': 'Nervous System',
  community: 'Community',
};
---

<BaseLayout title={`${title} — The Mama Tales`} description={description}>
  <article class="pt-32 pb-20 md:pb-28">
    <div class="max-w-3xl mx-auto px-6">
      <!-- Header -->
      <header class="mb-12 text-center">
        <div class="mb-4">
          <span class="inline-block text-xs tracking-[0.3em] uppercase text-sage bg-sage-pale px-4 py-1.5 rounded-full">
            {categoryLabels[category] ?? category}
          </span>
        </div>
        <h1 class="text-4xl md:text-5xl text-charcoal font-display leading-tight mb-6">{title}</h1>
        <p class="text-lg text-warm-grey leading-relaxed max-w-2xl mx-auto mb-6">{description}</p>
        <div class="flex items-center justify-center gap-4 text-sm text-warm-grey">
          <span>{formattedDate}</span>
          {formattedUpdated && (
            <span>· Updated {formattedUpdated}</span>
          )}
        </div>
      </header>

      <!-- Prose content -->
      <div class="prose">
        <slot />
      </div>

      <!-- Back link -->
      <div class="mt-16 pt-8 border-t border-light-grey/40">
        <a href="/journal/" class="inline-flex items-center gap-2 text-xs tracking-[0.2em] uppercase text-sage hover:text-sage-light transition-colors">
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
          Back to Journal
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
