---
import { Image } from 'astro:assets';
import { siteConfig } from '../../data/siteConfig';
import goldenHour from '../../assets/images/u5868562739_Magical_golden_hour_sunset_warm_amber_and_honey-t_15af2859-342e-4f32-8124-ed714f1b3f8e_1.png';
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background image with Ken Burns pan -->
  <div class="absolute inset-0 animate-ken-burns">
    <Image
      src={goldenHour}
      alt=""
      width={1920}
      height={1080}
      class="w-full h-full object-cover"
      quality={80}
    />
  </div>

  <!-- Overlay gradients for text readability -->
  <div class="absolute inset-0 bg-charcoal/35 md:bg-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-charcoal/65 via-charcoal/35 to-charcoal/15"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal/40 via-transparent to-charcoal/20"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-32 pb-24">
    <div class="max-w-2xl">
      <p class="text-xs tracking-[0.3em] uppercase text-champagne-light mb-5 font-body font-normal">
        {siteConfig.strapline}
      </p>
      <h1 class="text-5xl md:text-7xl text-warm-white leading-[1.08] mb-6 font-brand italic drop-shadow-sm">
        Rebirthing<br />
        <span class="text-champagne-light">Breathwork Mastery</span>
      </h1>
      <p class="text-lg md:text-xl text-warm-white/80 leading-relaxed max-w-lg mb-10 font-light drop-shadow-sm">
        Guiding women to self-master their life through conscious, intentional
        breathing. Awaken, reclaim and embody authentic living.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/services/"
          class="bg-sage hover:bg-sage-light text-warm-white px-8 py-3.5 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
        >
          Explore Services
        </a>
        <a
          href="/about/"
          class="border border-warm-white/30 hover:border-sage-light text-warm-white hover:text-sage-light px-8 py-3.5 rounded-full text-xs tracking-[0.2em] uppercase transition-all"
        >
          Meet Natalie
        </a>
      </div>
    </div>
  </div>

  <!-- Curved section divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 120L60 108C120 96 240 72 360 66C480 60 600 72 720 78C840 84 960 84 1080 78C1200 72 1320 60 1380 54L1440 48V120H0Z" fill="#FAF6F1"/>
    </svg>
  </div>
</section>
