---
import { Image } from 'astro:assets';
import { siteConfig } from '../../data/siteConfig';
import nataliePortrait from '../../assets/images/natalie-portrait.png';
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Muted pink-to-gold gradient (nod to original site, refined) -->
  <div class="absolute inset-0 bg-gradient-to-br from-dusty-rose via-dusty-rose-light to-champagne animate-gradient"></div>
  <div class="absolute inset-0 bg-gradient-to-tl from-champagne-light/50 via-transparent to-dusty-rose/30"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-warm-white/10 to-cream/20"></div>

  <!-- Soft veil on the left for text legibility -->
  <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 via-charcoal/15 to-transparent"></div>

  <!-- Organic floating shapes for depth -->
  <div class="absolute top-10 -right-20 w-[600px] h-[600px] bg-champagne/40 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-dusty-rose-light/40 rounded-full blur-3xl"></div>
  <div class="absolute top-1/4 right-1/3 w-80 h-80 bg-blush/30 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/3 right-1/4 w-64 h-64 bg-champagne-light/30 rounded-full blur-2xl"></div>
  <div class="absolute top-2/3 left-1/6 w-40 h-40 bg-dusty-rose/15 rounded-full blur-xl"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-32 pb-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Content -->
      <div class="text-center md:text-left">
        <p class="text-xs tracking-[0.3em] uppercase text-champagne-light mb-5 font-body font-normal">
          {siteConfig.strapline}
        </p>
        <h1 class="text-5xl md:text-7xl text-warm-white leading-[1.1] mb-6 font-brand italic drop-shadow-sm">
          The Mama<br />
          <span class="text-champagne-light">Tales</span>
        </h1>
        <p class="text-lg md:text-xl text-warm-white/80 leading-relaxed max-w-lg mb-10 font-light drop-shadow-sm">
          Rebirthing breathwork and nervous system regulation for parents who want to
          heal, connect and raise resilient children — from conception and beyond.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a
            href="/services/"
            class="bg-sage hover:bg-sage-light text-warm-white px-8 py-3.5 rounded-full text-xs tracking-[0.2em] uppercase transition-all hover:shadow-lg"
          >
            Explore Services
          </a>
          <a
            href="/about/"
            class="border border-warm-white/30 hover:border-sage-light text-warm-white hover:text-sage-light px-8 py-3.5 rounded-full text-xs tracking-[0.2em] uppercase transition-all"
          >
            Meet Natalie
          </a>
        </div>
      </div>

      <!-- Hero image placeholder — organic blob shape -->
      <div class="relative flex justify-center">
        <div class="relative w-80 h-96 md:w-96 md:h-[480px]">
          <!-- Decorative ring -->
          <div class="absolute -inset-4 rounded-[40%_60%_55%_45%/55%_45%_60%_40%] border-2 border-warm-white/30 rotate-6"></div>
          <div class="w-full h-full rounded-[40%_60%_55%_45%/55%_45%_60%_40%] overflow-hidden shadow-xl">
            <Image
              src={nataliePortrait}
              alt="Natalie Doyle with her daughter"
              width={480}
              height={600}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Curved section divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 120L60 108C120 96 240 72 360 66C480 60 600 72 720 78C840 84 960 84 1080 78C1200 72 1320 60 1380 54L1440 48V120H0Z" fill="#FAF6F1"/>
    </svg>
  </div>
</section>
