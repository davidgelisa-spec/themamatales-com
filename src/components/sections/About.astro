---
import { Image } from 'astro:assets';
import { qualifications } from '../../data/siteConfig';
import nataliePortrait from '../../assets/images/natalie-portrait.png';
import childWildflowers from '../../assets/images/child-wildflowers.png';
---

<section id="about" class="py-20 md:py-28 relative overflow-hidden scroll-mt-20">
  <!-- Layered background -->
  <div class="absolute inset-0 bg-gradient-to-b from-cream via-sage-pale/30 to-cream"></div>
  <div class="absolute top-0 right-0 w-1/2 h-full bg-sage-pale/30 rounded-l-[80px]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Image cluster -->
      <div class="relative h-[500px]">
        <!-- Large circular image — Natalie -->
        <div class="absolute top-0 left-0 w-72 h-72 rounded-full shadow-lg overflow-hidden">
          <Image
            src={nataliePortrait}
            alt="Natalie Doyle"
            width={288}
            height={288}
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Small offset circle — child in wildflowers -->
        <div class="absolute bottom-12 right-4 w-52 h-52 rounded-full shadow-lg overflow-hidden">
          <Image
            src={childWildflowers}
            alt="Women's breathwork circle"
            width={208}
            height={208}
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Decorative dots -->
        <div class="absolute top-1/2 right-1/3 w-8 h-8 rounded-full bg-sage-light/40"></div>
        <div class="absolute bottom-4 left-1/3 w-5 h-5 rounded-full bg-terracotta-light/40"></div>
      </div>

      <!-- Content -->
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-sage mb-3 font-body">Meet Natalie</p>
        <h2 class="text-4xl md:text-5xl text-charcoal mb-6 leading-tight font-display">
          Your breath holds the key.
        </h2>
        <p class="text-lg text-warm-grey leading-relaxed mb-6">
          Through rebirthing breathwork and nervous system regulation, I guide women home
          to their bodies — so they can live from a place of presence, power and authenticity.
        </p>
        <p class="text-warm-grey leading-relaxed mb-8">
          This isn't about being calm all the time. It's about widening your window of
          tolerance, building genuine resilience, and reclaiming the parts of yourself
          that got buried along the way. When you regulate, everything shifts.
        </p>

        <!-- Qualifications -->
        <div class="flex flex-wrap gap-2">
          {qualifications.map((q) => (
            <span class="text-xs tracking-wide bg-sage-pale text-sage px-3 py-1.5 rounded-full">
              {q}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
