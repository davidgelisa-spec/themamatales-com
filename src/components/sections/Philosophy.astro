---
const pillars = [
  {
    title: 'Breathe',
    description:
      'Rebirthing breathwork as a gateway to healing. Learn to use your breath to release stored tension, process emotions and return to a regulated, embodied state.',
    icon: '🍃',
  },
  {
    title: 'Regulate',
    description:
      'Understand your nervous system and widen your window of tolerance. Build the capacity to self-regulate — responding to life with clarity, not reactivity.',
    icon: '✦',
  },
  {
    title: 'Embody',
    description:
      'Move from knowing to being. Integrate breathwork into your daily life and step into the authentic, empowered version of yourself that was always there.',
    icon: '🤲',
  },
];
---

<section class="py-20 md:py-28 bg-charcoal text-warm-white relative overflow-hidden">
  <!-- Decorative shapes -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-sage/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-terracotta/8 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-xs tracking-[0.3em] uppercase text-sage-light mb-3">Our Philosophy</p>
      <h2 class="text-4xl md:text-5xl font-display mb-4">Breathe. Regulate. Embody.</h2>
      <p class="text-warm-white/60 max-w-2xl mx-auto">
        Three pillars that guide everything we do at Rebirthing Breathwork Mastery.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {pillars.map((pillar) => (
        <div class="text-center p-8 rounded-2xl bg-warm-white/5 border border-warm-white/10 hover:bg-warm-white/8 transition-colors">
          <div class="text-3xl mb-4">{pillar.icon}</div>
          <h3 class="text-2xl font-display italic text-sage-light mb-3">{pillar.title}</h3>
          <p class="text-warm-white/60 leading-relaxed text-sm">{pillar.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
